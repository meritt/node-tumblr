{
  "name": "tumblr",
  "version": "1.0.0",
  "description": "Wrapper for the Tumblr API",
  "keywords": [
    "api",
    "blog",
    "tumblr",
    "tumblr-api",
    "tumblr-oauth"
  ],
  "license": "MIT",
  "author": {
    "name": "Alexey Simonenko",
    "email": "alexey@simonenko.dev",
    "url": "http://simonenko.xyz"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/meritt/node-tumblr.git"
  },
  "files": [
    "lib"
  ],
  "type": "module",
  "sideEffects": false,
  "exports": "./lib/index.js",
  "scripts": {
    "lint": "oxlint",
    "format": "oxfmt",
    "format:check": "oxfmt --check",
    "test": "node --test test/*.js",
    "coverage": "mkdir -p coverage && node --test --experimental-test-coverage --test-coverage-lines=97 --test-coverage-branches=92 --test-coverage-functions=97 --test-reporter=spec --test-reporter-destination=stdout --test-reporter=lcov --test-reporter-destination=coverage/lcov.info test/*.js"
  },
  "devDependencies": {
    "oxfmt": "^0.54.0",
    "oxlint": "^1.69.0"
  },
  "engines": {
    "node": ">=26.3"
  },
  "packageManager": "pnpm@11.6.0"
}
